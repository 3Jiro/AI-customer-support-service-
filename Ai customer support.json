    {
      "parameters": {
        "jsCode": "// 1. Get the data from the Edit Fields node\nconst aiMsg = $json.ai_response.toLowerCase();\nconst realStatus = $json.actual_status.toLowerCase();\nconst realCarrier = $json.actual_carrier.toLowerCase();\n\n// 2. The Verification Logic\n// Does the AI's friendly message actually contain the words from the database?\nconst statusMatch = aiMsg.includes(realStatus);\nconst carrierMatch = aiMsg.includes(realCarrier);\n\nconst finalScore = (statusMatch && carrierMatch) ? 1.0 : 0.0;\n\nreturn {\n  final_response: $json.ai_response,\n  confidence_score: finalScore,\n  low_confidence: finalScore < 0.8,\n  reason: finalScore === 1.0 ? \"✅ Verified: AI response matches Database.\" : \"🚨 Hallucination: AI data mismatch!\",\n  verified: finalScore === 1.0\n};"
      },
